{
	"name": "mouse.rip",
	"version": "3.0.0",
	"private": true,
	"scripts": {
		"add-item": "bun ./scripts/add-item.js",
		"build": "next build",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
		"dev": "next dev --turbopack",
		"lint": "next lint",
		"preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
		"start": "next start",
		"update": "concurrently \"bun run update:*\"",
		"update:data": "bun ./scripts/update-data.js",
		"update:images": "concurrently \"bun run update:images:mice\" \"bun run update:images:items\"",
    "update:images:mice": "bun ./scripts/update-mice-images.js",
    "update:images:items": "bun ./scripts/update-item-images.js",
		"update:userscripts": "bun ./scripts/update-userscript-data.js"
	},
	"dependencies": {
		"@headlessui/react": "^2.2.4",
		"@heroicons/react": "^2.2.0",
		"@opennextjs/cloudflare": "^1.1.0",
		"clsx": "^2.1.1",
		"framer-motion": "^12.16.0",
		"next": "15.3.3",
		"postcss": "^8.5.4",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-virtualized-auto-sizer": "^1.0.26",
		"react-window": "^1.8.11",
		"zod": "^3.25.67"
	},
	"devDependencies": {
		"@clack/prompts": "^0.11.0",
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20.17.57",
		"@types/react": "^19.1.6",
		"@types/react-dom": "^19",
		"@types/react-window": "^1.8.8",
		"concurrently": "^9.2.1",
		"eslint": "^9",
		"eslint-config-next": "15.3.3",
		"tailwindcss": "^4.1.8",
		"typescript": "^5",
		"wrangler": "^4.19.1"
	}
}
